"1_title" = "Welcome to reMARK";
"1_content" = "We have made a few changes in the reMARK app. Press next to see what has changed.";
"2_title" = "Azure Application Proxy with AD pre-authentication";
"2_content" = "Now you can use Active Directory pre-authentication to login to reMARK through Azure Application Proxy.";
"3_title" = "Share options support";
"3_content" = "Now you can share images, files and text from other applications to reMARK app.";
"4_title" = "Spacebar marking as read support for M1 Silicon";
"4_content" = "Now app version for Apple Silicon M1 supports using spacebar button for marking emails as read.";
"5_title" = "Possibility to include attachments in replies";
"5_content" = "Now it is possible to include source email attachments in replies to that email";
