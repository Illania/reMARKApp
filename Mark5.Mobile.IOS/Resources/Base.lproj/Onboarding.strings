"1_title" = "Welcome to reMARK";
"1_content" = "We have made a few changes in the reMARK app. Press next to see what has changed.";
"2_title" = "Favorite categories";
"2_content" = "Now you can set favorite categories for quick assignment.";
"3_title" = "Message list appearance";
"3_content" = "Now you can use different font and cell colors to highlight email by different criterias.";
"4_title" = "Extra fields management";
"4_content" = "Now you can manage extra fields values and switch on/off their visibility.";
"5_title" = "Bookmarks for emails";
"5_content" = "Now you can assign a bookmark for each email folder.";
"6_title" = "Spotlight search for contacts";
"6_content" = "Now you can search for reMARK contacts in Spotlight search.";
"7_title" = "File to folder after sending email";
"7_content" = "Now you can file an email to a folder immediately after sending it.";
"8_title" = "Attach external documnets";
"8_content" = "Now you can add a reMARK external document as an attachment.";
"9_title" = "Copy to department todo list";
"9_content" = "Now you can copy an email either to a user or to a department todo list.";
"10_title" = "Add a contact from an email header";
"10_content" = "Now you can add a new contact by clicking on an email recipient field.";
