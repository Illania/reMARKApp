    <android.support.v7.preference.PreferenceScreen android:key="@string/pref_key_cat_account" android:title="@string/pref_cat_account">
        <android.support.v7.preference.Preference android:key="@string/pref_key_account_username" android:title="@string/pref_account_username_title" />
        <android.support.v7.preference.Preference android:key="@string/pref_key_account_hostname" android:title="@string/pref_account_hostname_title" />
        <android.support.v7.preference.Preference android:key="@string/pref_key_account_port" android:title="@string/pref_account_port_title" />
