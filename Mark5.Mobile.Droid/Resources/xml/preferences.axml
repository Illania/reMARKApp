    </android.support.v7.preference.PreferenceScreen>
    <android.support.v7.preference.PreferenceScreen android:key="@string/pref_key_cat_advanced" android:title="@string/pref_cat_advanced">
        <android.support.v7.preference.CheckBoxPreference android:key="@string/pref_key_advanced_enable_reporting" android:title="@string/pref_advanced_enable_reporting_title" android:summaryOn="@string/pref_advanced_enable_reporting_summary_on" android:summaryOff="@string/pref_advanced_enable_reporting_summary_off" android:defaultValue="@bool/pref_advanced_enable_reporting_default" />
