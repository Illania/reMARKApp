    <android.support.v7.preference.PreferenceScreen android:key="@string/pref_key_cat_about" android:title="@string/pref_cat_about">
        <android.support.v7.preference.Preference android:key="@string/pref_key_about_send_feedback" android:title="@string/pref_about_send_feedback_title" android:summary="@string/pref_about_send_feedback_summary" />
        <android.support.v7.preference.Preference android:key="@string/pref_key_about_privacy_policy" android:title="@string/pref_about_privacy_policy_title" android:summary="@string/pref_about_privacy_policy_summary" />
