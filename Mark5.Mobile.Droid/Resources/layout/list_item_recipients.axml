<?xml version="1.0" encoding="utf-8"?>
<android.support.v7.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/white" android:paddingTop="6dp" android:paddingBottom="4dp" android:paddingLeft="8dp" android:paddingRight="8dp" android:orientation="vertical">
