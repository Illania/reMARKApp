<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:animateLayoutChanges="true">
    <LinearLayout
        android:id="@+id/start_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/lightgray">
            <View
                android:background="@color/darkblue"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_centerInParent="true" />
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/white">
            <android.support.v7.widget.AppCompatButton
                android:id="@+id/start_button"
                android:text="@string/download"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:textColor="@color/white"
                style="@style/mark5colorbutton" />
            <android.support.v7.widget.AppCompatTextView
                android:id="@+id/last_downloaded_on_text_view"
                android:textAppearance="@style/fontPrimaryLight"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_below="@id/start_button"
                android:layout_centerHorizontal="true" />
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/progress_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/darkerblue">
            <View
                android:id="@+id/progress_placeholder"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_centerInParent="true" />
            <View
                android:id="@+id/progress_warning_image"
                android:background="@color/white"
                android:layout_width="75dp"
                android:layout_height="75dp"
                android:layout_marginBottom="25dp"
                android:layout_centerHorizontal="true"
                android:layout_above="@id/progress_placeholder" />
            <android.support.v7.widget.AppCompatTextView
                android:text="@string/dont_close_app"
                android:textAppearance="@style/fontSmallLight"
                android:textColor="@color/lightgray"
                android:gravity="center"
                android:layout_marginLeft="25dp"
                android:layout_marginRight="25dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_below="@id/progress_placeholder" />
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/white">
            <android.support.v7.widget.AppCompatTextView
                android:id="@+id/progress_status"
                android:text="@string/preparing"
                android:textAppearance="@style/fontSmall"
                android:gravity="center"
                android:layout_marginLeft="25dp"
                android:layout_marginRight="25dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true" />
            <ProgressBar
                android:id="@+id/progress_bar"
                android:indeterminate="true"
                android:layout_marginLeft="50dp"
                android:layout_marginRight="50dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="10dp"
                android:layout_above="@id/progress_status"
                style="@style/mark5progressbarhorizontaldark" />
            <android.support.v7.widget.AppCompatButton
                android:id="@+id/cancel_button"
                android:text="@string/cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="25dp"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:textColor="@color/darkblue"
                style="@style/mark5colorbuttonflat" />
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/finished_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/lightgray">
            <View
                android:background="@color/darkblue"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_centerInParent="true" />
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/white">
            <android.support.v7.widget.AppCompatButton
                android:id="@+id/close_button"
                android:text="@string/continue_work"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:textColor="@color/white"
                style="@style/mark5colorbutton" />
            <android.support.v7.widget.AppCompatTextView
                android:text="@string/download_finished"
                android:textAppearance="@style/fontPrimaryLight"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:layout_above="@id/close_button"
                android:layout_centerHorizontal="true" />
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>