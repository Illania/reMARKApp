<?xml version="1.0" encoding="utf-8"?>
<resources>
	<style name="mark5" parent="mark5Base">
	</style>
	<style name="mark5Base" parent="Theme.AppCompat.Light.NoActionBar">
		<item name="colorPrimary">@color/darkerblue</item>
		<item name="colorPrimaryDark">@color/darkerblue</item>
		<item name="colorAccent">@color/brown</item>
		<item name="colorButtonNormal">@color/lightgray</item>
		<item name="colorControlHighlight">@color/brown</item>
		<item name="actionBarItemBackground">@color/darkblue</item>
		<item name="actionModeBackground">@color/darkblue</item>
		<item name="spinnerStyle">@style/mark5spinner</item>
		<item name="preferenceTheme">@style/mark5preference</item>
		<item name="alertDialogTheme">@style/mark5dialog</item>
	</style>
	<style name="mark5Splash" parent="mark5">
		<item name="android:windowFullscreen">true</item>
		<item name="android:windowContentOverlay">@null</item>
		<item name="android:windowBackground">@mipmap/background</item>
		<item name="windowNoTitle">true</item>
		<item name="windowActionBar">false</item>
	</style>
	<style name="mark5spinner" parent="Widget.AppCompat.Spinner.Underlined" />
	<style name="mark5appbaroverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
	<style name="mark5popupoverlay" parent="ThemeOverlay.AppCompat.Light" />
	<style name="mark5navheaderoverlay" parent="ThemeOverlay.AppCompat.Dark" />
	<style name="mark5preference" parent="PreferenceThemeOverlay.v14.Material" />
	<style name="mark5dialog" parent="Theme.AppCompat.Light.Dialog.Alert">
		<item name="colorAccent">@color/brown</item>
	</style>
</resources>