<?xml version="1.0" encoding="UTF-8"?>
<resources>
	<style name="mark5" parent="Theme.AppCompat.Light.DarkActionBar">
		<item name="colorPrimary">@color/darkblue</item>
		<item name="colorPrimaryDark">@color/darkerblue</item>
		<item name="colorAccent">@color/brown</item>
		<item name="actionBarItemBackground">@color/darkblue</item>
		<item name="actionModeBackground">@color/darkblue</item>
		<!--Not AppCompat compatible attributes-->
		<item name="android:windowBackground">@color/white</item>
		<item name="android:navigationBarColor">@color/darkerblue</item>
		<item name="android:statusBarColor">@color/darkerblue</item>
		<item name="android:colorLongPressedHighlight">@color/lightbrown</item>
		<item name="android:colorActivatedHighlight">@color/lightbrown</item>
		<item name="android:textColorHighlight">@color/lightbrown</item>
		<item name="android:textColorPrimary">@color/black</item>
		<!--General attributes  -->
		<!--We will be using the toolbar so no need to show ActionBar-->
		<item name="windowActionBar">false</item>
		<!--If you are using revision 22.1 please use just windowNoTitle. Without android:-->
		<item name="windowNoTitle">true</item>
		<!--If set to false the actions push the toolbar down -->
		<item name="windowActionModeOverlay">true</item>
		<item name="alertDialogTheme">@style/AlertDialogCustom</item>
	</style>
	<style name="AlertDialogCustom" parent="Theme.AppCompat.Light.Dialog.Alert">
		<item name="android:colorAccent">@color/brown</item>
	</style>
</resources>