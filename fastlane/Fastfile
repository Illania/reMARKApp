#region Teams
def ios_teams_on_build_success()
  teams_bot(
    teams_url: ENV['TEAMS_DEV_URL'],
    title: "reMARK app build",
    text: "",
    activity_title: "reMARK app has been successfully built!",
    activity_image: ENV['TEAMS_REMARK_ICON_LINK'],
    facts: [
          {
            "name" => "Platform",
            "value" => "iOS"
          },
          {
            "name" => "Version",
            "value" => ios_version
          },
          {
            "name" => "Build number",
            "value" => ios_build_number
          }
        ],
        theme_color: "321244",
        use_markdown: true
  )
  end

  def ios_teams_on_publish_success(release_type)
  message = ios_get_text_for_release_type(release_type)
  teams_url = ENV['TEAMS_URL']
  if release_type=='Test'
    teams_url = ENV['TEAMS_DEV_URL']
  end
  teams_bot(
    teams_url: teams_url,
    title: "reMARK app release",
    text: "",
    activity_title: message,
    activity_image: ENV['TEAMS_REMARK_ICON_LINK'],
    facts: [
          {
            "name" => "Platform",
            "value" => "iOS"
          },
          {
            "name" => "Version",
            "value" => ios_version
          },
          {
            "name" => "Build number",
            "value" => ios_build_number
          },
          {
            "name" => "Release notes",
            "value" => ios_get_release_notes
          }
        ],
        theme_color: "321244",
        use_markdown: true
  )
  end

  def ios_get_release_notes()
      return File.read(ENV['IOS_RELEASE_NOTES_PATH'])
  end

  def ios_get_release_confluence_page_link()
    return "[iOS Release Notes](#{ENV['IOS_RELEASE_CONFLUENCE_LINK']})"
  end

  def get_user_guides_confluence_page_link()
    numbers = ios_version.scan(/\d+\.\d+/)
    major_minor_version = numbers.first
    return "[User guides](#{ENV['USER_GUIDES_CONFLUENCE_LINK']}/#{major_minor_version})"
  end

  def get_test_plan_confluence_page_link()
    return "[Test plan](#{ENV['TEST_PLAN_CONFLUENCE_LINK']})"
  end

  def ios_get_text_for_release_type(release_type)
    text = ""
    if release_type == 'Test'
      text << "reMARK iOS app Dev Test Beta version #{ios_version()} (build #{((ios_build_number()))}) has been successfully uploaded to Testflight.\n"
    elsif release_type == 'Internal Beta'
      text << "reMARK iOS app Internal Beta version #{ios_version()} (build #{ios_build_number()}) has been successfully uploaded to Testflight.\n"
    elsif release_type == "Public Beta"
      text << "reMARK iOS app Public Beta version #{ios_version()} (build #{ios_build_number()}) has been successfully uploaded to Testflight.\n"
    else
      text = "reMARK iOS app Public Beta version #{ios_version()} (build #{ios_build_number()}) has been successfully uploaded to AppStore.\n"
    end
    text << "Please refer to #{ios_get_release_confluence_page_link()} for complete resolved tickets list.\n"
    text << "Also please check out #{get_user_guides_confluence_page_link()} to see setup guides for new features.\n"

    if release_type == 'Internal Beta'
      text << "Note for Support Team: please download and check out the updated #{get_test_plan_confluence_page_link()}."
    end
    return text
  end

  def teams_on_error(exception)
  teams_bot(
    teams_url: ENV['TEAMS_DEV_URL'],
    title: "reMARK app build",
    text: "",
    activity_title: "Error occured!",
    activity_image: ENV['TEAMS_ERROR_ICON_LINK'],
    facts:[
      {
        "name" => "Error message",
        "value" => exception
      }
    ]
  )
  end
#endregion

