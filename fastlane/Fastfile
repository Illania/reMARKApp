require 'nokogiri'

default_platform(:ios)

platform :ios do

#region Certificates
  desc 'Generate certificates'
  lane :generate_certificates do |options|
    app_bundles = ['com.nordic-it.mark5.mobile.ios',
                   'com.nordic-it.mark5.mobile.ios.callid',
                   'com.nordic-it.mark5.mobile.ios.share']

    sync_code_signing(
      type: options[:type],
      app_identifier: app_bundles,
      force_for_new_devices: true,
      readonly: false
    )
  end
#endregion

#region Versioning
  def ios_version
    get_info_plist_value(path: ENV['INFO_PLIST_MOBILE_IOS_PATH'],
                         key: 'CFBundleShortVersionString')
  end

  def ios_build_number
    get_info_plist_value(path: ENV['INFO_PLIST_MOBILE_IOS_PATH'],
                         key: 'CFBundleVersion')
  end
#endregion

#region Build
  def update_entitlements
    update_plist(
      plist_path: ENV['ENTITLEMENTS_PLIST_PATH'],
      block: proc do |plist|
        plist[:"aps-environment"] = 'production'
        plist[:"com.apple.developer.icloud-container-environment"] = 'Production'
      end
    )
  rescue StandardError => e
    slack_on_error(e)
  end

  desc 'Build iOS app release'
  lane :build_release do |options|
    begin
      bump_version(platform: 'iOS', type: options[:version_type], info_plist_pathes: ENV['INFO_PLIST_PATHES'])
      bump_code(platform: 'iOS', info_plist_pathes: ENV['INFO_PLIST_PATHES'])
      update_entitlements
      dotnet(
        action: options[:action].nil? ? 'publish' : options[:action],
        project: ENV['IOS_PROJECT_PATH'],
        runtime_identifier: 'ios-arm64',
        framework: 'net8.0-ios',
        output_path: ENV['IOS_OUTPUT_PATH'],
        target: options[:target],
        configuration: options[:configuration].nil? ? 'Release' : options[:configuration],
        ipa_name: 'remark.ipa'
      )
<<<<<<< Updated upstream
      slack_on_success
    rescue StandardError => e
      slack_on_error(e)
    end
=======
      ios_message_on_build_success()
    rescue StandardError => e
      message_on_error(e)
    end
  end
#endregion

#region Messaging
def ios_message_on_build_success()
  if ENV['DEFAULT_MESSENGER']=='slack'
    ios_slack_on_success('reMARK iOS app has been successfully published', 'iOS')
  elsif ENV['DEFAULT_MESSENGER']=='teams'
    ios_teams_on_build_success()
  else
    raise "Messenger not supported"
  end
end

def ios_message_on_publish_success(release_type)
  if ENV['DEFAULT_MESSENGER']=='slack'
    ios_slack_on_success('reMARK iOS app has been successfully published', 'iOS')
  elsif ENV['DEFAULT_MESSENGER']=='teams'
    ios_teams_on_publish_success(release_type)
  else
    raise "Messenger not supported"
>>>>>>> Stashed changes
  end
end

def message_on_error(exception)
  if ENV['DEFAULT_MESSENGER']=='slack'
    slack_on_error(exception)
  elsif ENV['DEFAULT_MESSENGER']=='teams'
    teams_on_error(exception)
  else
    raise "Messenger not supported"
  end
end
#endregion

