platform :android do

#region Versioning

  def android_version
    File.open(ENV['ANDROID_MANIFEST_PATH']) do |f|
      @doc = Nokogiri::XML(f)
      current_version = @doc.at('//manifest/@android:versionName').text
      return current_version.to_s
    end
  end

  def android_build_number
    File.open(ENV['ANDROID_MANIFEST_PATH']) do |f|
      @doc = Nokogiri::XML(f)
      current_build = @doc.at('//manifest/@android:versionCode').text
      return current_build.to_s
    end
  end

#endregion

#region Messaging
def android_message_on_build_success()
  if ENV['DEFAULT_MESSENGER']=='slack'
    android_slack_on_success('reMARK Android app has been successfully published', 'Android')
  elsif ENV['DEFAULT_MESSENGER']=='teams'
    android_teams_on_build_success()
  else
    raise "Messenger not supported"
  end
end

def android_message_on_publish_success(release_type)
  if ENV['DEFAULT_MESSENGER']=='slack'
    android_slack_on_success('reMARK Android app has been successfully published', 'Android')
  elsif ENV['DEFAULT_MESSENGER']=='teams'
    android_teams_on_publish_success(release_type)
  else
    raise "Messenger not supported"
  end
end

#endregion

#region Slack
def android_slack_on_success(message, platform)
  slack(
    slack_url: ENV['SLACK_URL'],
    message: message,
    channel: ENV['SLACK_CHANNEL'],
    success: true,
    attachment_properties: { fields: [{ title: 'Platform', value: platform },
                                      { title: 'Version', value: android_version },
                                      { title: 'Build number', value: android_build_number }] }
  )
end

def android_slack_on_error(exception)
  slack(
    slack_url: ENV['SLACK_URL'],
    message: 'Error occured ☹️!',
    channel: ENV['SLACK_CHANNEL'],
    success: false,
    attachment_properties: { fields: [{ title: 'Error message', value: exception }] }
  )
end
#endregion

#region Teams
def android_teams_on_build_success()
  teams_bot(
    teams_url: ENV['TEAMS_DEV_URL'],
    title: "reMARK app build",
    text: "",
    activity_title: "reMARK app has been successfully built!",
    activity_image: ENV['TEAMS_REMARK_ICON_LINK'],
    facts: [
          {
            "name" => "Platform",
            "value" => "Android"
          },
          {
            "name" => "Version",
            "value" => android_version
          },
          {
            "name" => "Build number",
            "value" => android_build_number
          }
        ],
        theme_color: "321244",
        use_markdown: true
  )
end

def android_teams_on_publish_success(release_type)
  message = android_get_text_for_release_type(release_type)
  teams_url = ENV['TEAMS_URL']
  if release_type=='Test'
    teams_url = ENV['TEAMS_DEV_URL']
  end
  teams_bot(
    teams_url: teams_url,
    title: "reMARK app release",
    text: "",
    activity_title: message,
    activity_image: ENV['TEAMS_REMARK_ICON_LINK'],
    facts: [
          {
            "name" => "Platform",
            "value" => "Android"
          },
          {
            "name" => "Version",
            "value" => android_version
          },
          {
            "name" => "Build number",
            "value" => android_build_number
          },
          {
            "name" => "Release notes",
            "value" => android_get_release_notes
          }
        ],
        theme_color: "321244",
        use_markdown: true
  )
  end

def android_get_text_for_release_type(release_type)
  text = ""
  if release_type == 'Test'
    text << "reMARK Android app Dev Test Beta version #{android_version()} (build #{android_build_number()}) has been successfully published.\n"
  elsif release_type == 'Internal Beta'
    text << "reMARK Android app Internal Beta version #{android_version()} (build #{android_build_number()}) has been successfully uploaded to #{android_get_installers_confluence_page_link()}.\n"
  elsif release_type == "Public Beta"
    text << "reMARK Android app Public Beta version #{android_version()} (build #{android_build_number()}) has been successfully uploaded to Google Play Beta.\n"
  else
    text << "reMARK Android app Public Beta version #{android_version()} (build #{android_build_number()}) has been successfully uploaded to AppStore.\n"
  end
  text << "Please refer to #{android_get_release_confluence_page_link()} for complete resolved tickets list.\n"
  text <<  "Also please check out #{get_user_guides_confluence_page_link()} to see setup guides for new features.\n"

  if release_type == 'Internal Beta'
    text << "Note for Support Team: please download and check out the updated #{get_test_plan_confluence_page_link()}."
  end
  return text
end

def android_get_release_notes()
  return File.read("#{ENV['ANDROID_RELEASE_NOTES_PATH']}/#{android_build_number()}.txt")
end

def android_get_release_confluence_page_link()
  return "[Android Release Notes](#{ENV['ANDROID_RELEASE_CONFLUENCE_LINK']})"
end

def android_get_installers_confluence_page_link()
  return "[Android Installers Confluence Page](#{ENV['ANDROID_INSTALLERS_CONFLUENCE_LINK']})"
end
#endregion

#region Build

  desc 'Build Android app release'
  lane :build_release do |options|
    begin
      bump_version(platform: 'Android', type: options[:version_type], manifest_file_path: ENV['ANDROID_MANIFEST_PATH'])
      bump_code(platform: 'Android', manifest_file_path: ENV['ANDROID_MANIFEST_PATH'])
      dotnet(
        action: options[:action].nil? ? 'publish' : options[:action],
        project: ENV['ANDROID_PROJECT_PATH'],
        framework: 'net8.0-android',
        output_path: ENV['ANDROID_OUTPUT_PATH'],
        target: options[:target],
        configuration: options[:configuration].nil? ? 'Release' : options[:configuration],
        sign_apk: true,
        android_signing_keystore: ENV['PATH_TO_KEYSTORE'],
        android_signing_key_alias: ENV['ANDROID_SIGNING_KEY_ALIAS'],
        android_signing_key_pass: ENV['ANDROID_SIGNING_KEY_PASS'],
        android_signing_store_pass: ENV['ANDROID_SIGNING_STORE_PASS']
      )
      android_message_on_build_success()
    rescue StandardError => e
      message_on_error(e)
    end
  end

#endregion

